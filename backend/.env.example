# ---- LLM provider ----------------------------------------------------------
# One of: ollama | groq | deepseek
# Default is ollama so the app runs locally with no API key.
LLM_PROVIDER=ollama

# Hosted providers (OpenAI-compatible). Fill the one you use.
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Model names per tier. Sensible defaults are applied per provider in config.py,
# but you can override them here.
# Ollama examples:   MODEL_FAST=qwen3.5:2b  MODEL_STANDARD=qwen3.5:9b  MODEL_COMPLEX=qwen3.5:9b
# Groq examples:     MODEL_FAST=llama-3.1-8b-instant  MODEL_STANDARD=llama-3.3-70b-versatile
# DeepSeek examples: MODEL_STANDARD=deepseek-chat  MODEL_COMPLEX=deepseek-reasoner
MODEL_FAST=
MODEL_STANDARD=
MODEL_COMPLEX=

OLLAMA_HOST=http://localhost:11434

# ---- Database --------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://aftersales:aftersales@localhost:5432/aftersales

# ---- App -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
